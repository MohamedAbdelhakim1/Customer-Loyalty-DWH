                  name="OLE DB Source"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">DECLARE @StartDate DATE,
        @EndDate   DATE;

SELECT
    @StartDate = DATEADD(YEAR, -5,
                    DATEADD(DAY, 1 - DAY(MIN([Date])), MIN([Date]))),
    @EndDate   = DATEADD(YEAR,  5,
                    DATEADD(DAY, 1 - DAY(MAX([Date])), MAX([Date])))
FROM Calendar;

WITH Months AS (
    SELECT @StartDate AS MonthDate
    UNION ALL
    SELECT DATEADD(MONTH, 1, MonthDate)
    FROM Months
    WHERE MonthDate &lt; @EndDate
)
SELECT
    YEAR(MonthDate) * 100 + MONTH(MonthDate)               AS DateKey,
    YEAR(MonthDate)                                         AS Year,
    MONTH(MonthDate)                                        AS Month,
    DATEPART(QUARTER, MonthDate)                            AS Quarter,
    DATENAME(MONTH, MonthDate)                              AS MonthName,
    CAST(YEAR(MonthDate) AS NVARCHAR(4)) + '-' +
    RIGHT('0' + CAST(MONTH(MonthDate) AS NVARCHAR(2)), 2)  AS Date
FROM Months
OPTION (MAXRECURSION 0);</property>
